        // Global variables
        let currentSubject = 'Math';
        const chatMessages = document.getElementById('chatMessages');
        const messageInput = document.getElementById('messageInput');
        const sendBtn = document.getElementById('sendBtn');
        const typingIndicator = document.getElementById('typingIndicator');

        // Subject buttons
        function setSubject(subject) {
            currentSubject = subject;
            document.querySelectorAll('.subject-btn').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');
            
            // Add subject context to input
            const subjectPrompts = {
                'Math': 'Solve this math problem: ',
                'Science': 'Explain this science concept: ',
                'English': 'Help me with this English homework: ',
                'History': 'Explain this history topic: ',
                'Other': ''
            };
            messageInput.placeholder = subjectPrompts[subject] || 'Ask anything...';
        }

        // Send message
        function sendMessage() {
            const message = messageInput.value.trim();
            if (!message) return;

            // Add user message
            addMessage(message, 'user');
            messageInput.value = '';
            sendBtn.disabled = true;
            sendBtn.textContent = '🤖 THINKING...';

            // Show typing indicator
            typingIndicator.style.display = 'block';
            scrollToBottom();

            // Simulate AI response
            setTimeout(() => {
                generateAIResponse(message);
            }, 1500 + Math.random() * 2000);
        }

        // Add message to chat
        function addMessage(text, sender) {
            const messageDiv = document.createElement('div');
            messageDiv.className = `message ${sender}`;
            messageDiv.innerHTML = `<div class="message-content">${text}</div>`;
            chatMessages.appendChild(messageDiv);
            scrollToBottom();
        }

        // AI Response Generator
        function generateAIResponse(userMessage) {
            typingIndicator.style.display = 'none';
            sendBtn.disabled = false;
            sendBtn.textContent = '🚀 SOLVE';

            // Smart responses based on subject and keywords
            let response = generateSmartResponse(userMessage, currentSubject);
            
            setTimeout(() => {
                addMessage(response, 'ai');
            }, 500);
        }

        // Smart AI Response System
        function generateSmartResponse(question, subject) {
            question = question.toLowerCase();

            // Math Solver
            if (subject === 'Math' || question.includes('solve') || question.includes('equation')) {
                if (question.includes('2x + 5 = 15')) {
                    return `🧮 **Math Solution:**<br>
                    2x + 5 = 15<br>
                    2x = 15 - 5<br>
                    2x = 10<br>
                    **x = 5** ✅<br><br>
                    <strong>Step-by-step:</strong><br>
                    1. Subtract 5 from both sides<br>
                    2. Divide both sides by 2<br>
                    3. Solution: x = 5`;
                }
                if (question.includes('area') || question.includes('triangle')) {
                    return `📐 **Triangle Area Formula:**<br>
                    Area = (1/2) × base × height<br><br>
                    **Example:** base = 6cm, height = 4cm<br>
                    Area = 0.5 × 6 × 4 = **12 cm²** ✅`;
                }
                return `🧮 **Math Helper:** "${question}"<br><br>
                📝 **General Steps to Solve:**<br>
                1. Identify the type (equation, geometry, etc.)<br>
                2. Write down given values<br>
                3. Apply correct formula<br>
                4. Substitute values<br>
                5. Calculate answer<br><br>
                💡 Send specific problem for detailed solution!`;
            }

            // Science
            if (subject === 'Science') {
                if (question.includes('newton') || question.includes('force')) {
                    return `🔬 **Newton's Laws:**<br>
                    <strong>1st Law:</strong> Object stays at rest/motion unless force acts<br>
                    <strong>2nd Law:</strong> F = ma (Force = mass × acceleration)<br>
                    <strong>3rd Law:</strong> Every action has equal opposite reaction<br><br>
                    **Formula:** F = m × a ✅`;
                }
                return `🔬 **Science Helper:**<br>
                Tell me the topic (Physics/Chemistry/Biology) and specific question! 📚`;
            }

            // English
            if (subject === 'English') {
                if (question.includes('grammar') || question.includes('sentence')) {
                    return `📝 **Grammar Rules:**<br>
                    <strong>Subject-Verb Agreement:</strong><br>
                    - He <strong>runs</strong> (not run)<br>
                    - They <strong>run</strong> (not runs)<br><br>
                    **Common Errors:**<br>
                    ❌ I am go → ✅ I am <strong>going</strong><br>
                    ❌ She don't → ✅ She <strong>doesn't</strong>`;
                }
                return `📚 **English Helper:**<br>
                Need help with grammar, essay writing, or literature?<br>
                Share your specific question! ✍️`;
            }

            // Default responses
            const responses = [
                `🤖 Great question! "${question}"<br><br>Let me break it down:<br>1. 📖 Understand the problem<br>2. 🔍 Identify key concepts<br>3. 📝 Apply formulas/steps<br>4. ✅ Verify solution<br><br>💡 Share more details for exact answer!`,
                `🎯 **Smart Solution Steps:**<br><br>
                **Step 1:** Write what you know<br>
                **Step 2:** Choose right formula<br>
                **Step 3:** Plug in numbers<br>
                **Step 4:** Calculate carefully<br><br>
                📝 Need specific help? Ask away!`
            ];

            return responses[Math.floor(Math.random() * responses.length)];
        }

        // Utility functions
        function scrollToBottom() {
            chatMessages.scrollTop = chatMessages.scrollHeight;
        }

        // Enter key support
        messageInput.addEventListener('keypress', function(e) {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendMessage();
            }
        });

        // Auto-resize textarea
        messageInput.addEventListener('input', function() {
            this.style.height = 'auto';
            this.style.height = Math.min(this.scrollHeight, 120) + 'px';
        });

        // Initialize
        messageInput.focus();
    </script>
</body>
</html>
